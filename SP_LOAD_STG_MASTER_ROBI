CREATE OR REPLACE PROCEDURE OWN_AP12008.SP_LOAD_STG_MASTER_ROBI_DELTA
AS
    v_current_batch_date    DATE;
    v_count_new             NUMBER := 0;
    v_count_changed         NUMBER := 0;
    v_count_deleted         NUMBER := 0;
    v_start_time            TIMESTAMP := SYSTIMESTAMP;

BEGIN

    -- ----------------------------------------------------------------
    -- STEP 1: Get current batch date
    -- ----------------------------------------------------------------
    SELECT MAX(BATCH_DATE)
    INTO v_current_batch_date
    FROM OWN_AP12008.STG_MASTER_ROBI;

    IF v_current_batch_date IS NULL THEN
        RAISE_APPLICATION_ERROR(
            -20001,
            'SP_LOAD_STG_MASTER_ROBI_DELTA: STG_MASTER_ROBI is empty.'
        );
    END IF;

    -- ----------------------------------------------------------------
    -- STEP 2: Compute hash for all current rows
    -- ORA_HASH concatenates all tracked columns into one fingerprint.
    -- Like grinding all ingredients into one smoothie —
    -- if any ingredient changes, the smoothie tastes different.
    -- ----------------------------------------------------------------
    -- STEP 2a: Detect NEW identities
    -- REFOG exists in STG_MASTER_ROBI but NOT in hash table
    -- ----------------------------------------------------------------
    INSERT INTO OWN_AP12008.STG_MASTER_ROBI_DELTA
        (REFOG, CHANGE_TYPE, BATCH_DATE, DETECTED_ON, IS_PROCESSED)
    SELECT
        r.REFOG,
        'NEW',
        v_current_batch_date,
        SYSTIMESTAMP,
        'N'
    FROM OWN_AP12008.STG_MASTER_ROBI r
    WHERE r.REFOG IS NOT NULL
      AND NOT EXISTS (
          SELECT 1
          FROM OWN_AP12008.STG_MASTER_ROBI_HASH h
          WHERE h.REFOG = r.REFOG
      );

    v_count_new := SQL%ROWCOUNT;

    -- Insert hash rows for new identities
    INSERT INTO OWN_AP12008.STG_MASTER_ROBI_HASH
        (REFOG, ROW_HASH, IS_ACTIVE, FIRST_SEEN_ON, LAST_SEEN_ON)
    SELECT
        r.REFOG,
        ORA_HASH(
            r.ROBID        || '|' ||
            r.FLID         || '|' ||
            r.START_DATE   || '|' ||
            r.END_DATE     || '|' ||
            r.ENTITYID     || '|' ||
            r.ENTITY       || '|' ||
            r.MANAGER      || '|' ||
            r.LASTNAME     || '|' ||
            r.FIRSTNAME    || '|' ||
            r.COUNTRY      || '|' ||
            r.LANGUAGE     || '|' ||
            r.FUNCTION     || '|' ||
            r.EMAIL        || '|' ||
            r.TYPE         || '|' ||
            r.STATUS       || '|' ||
            r.ISTEST       || '|' ||
            r.ISRPA        || '|' ||
            r.USER_TYPE
        ),
        'Y',
        v_current_batch_date,
        v_current_batch_date
    FROM OWN_AP12008.STG_MASTER_ROBI r
    WHERE r.REFOG IS NOT NULL
      AND NOT EXISTS (
          SELECT 1
          FROM OWN_AP12008.STG_MASTER_ROBI_HASH h
          WHERE h.REFOG = r.REFOG
      );

    -- ----------------------------------------------------------------
    -- STEP 2b: Detect CHANGED identities
    -- REFOG exists in both tables but hash differs
    -- Like comparing today's fingerprint against the filing cabinet —
    -- same person, different print = something changed
    -- ----------------------------------------------------------------
    INSERT INTO OWN_AP12008.STG_MASTER_ROBI_DELTA
        (REFOG, CHANGE_TYPE, BATCH_DATE, DETECTED_ON, IS_PROCESSED)
    SELECT
        r.REFOG,
        'CHANGED',
        v_current_batch_date,
        SYSTIMESTAMP,
        'N'
    FROM OWN_AP12008.STG_MASTER_ROBI r
    JOIN OWN_AP12008.STG_MASTER_ROBI_HASH h
        ON h.REFOG = r.REFOG
    WHERE r.REFOG IS NOT NULL
      AND h.IS_ACTIVE = 'Y'
      AND h.ROW_HASH != ORA_HASH(
            r.ROBID        || '|' ||
            r.FLID         || '|' ||
            r.START_DATE   || '|' ||
            r.END_DATE     || '|' ||
            r.ENTITYID     || '|' ||
            r.ENTITY       || '|' ||
            r.MANAGER      || '|' ||
            r.LASTNAME     || '|' ||
            r.FIRSTNAME    || '|' ||
            r.COUNTRY      || '|' ||
            r.LANGUAGE     || '|' ||
            r.FUNCTION     || '|' ||
            r.EMAIL        || '|' ||
            r.TYPE         || '|' ||
            r.STATUS       || '|' ||
            r.ISTEST       || '|' ||
            r.ISRPA        || '|' ||
            r.USER_TYPE
          );

    v_count_changed := SQL%ROWCOUNT;

    -- Update hash for changed identities
    UPDATE OWN_AP12008.STG_MASTER_ROBI_HASH h
    SET
        h.ROW_HASH    = ORA_HASH(
            (SELECT
                r.ROBID        || '|' ||
                r.FLID         || '|' ||
                r.START_DATE   || '|' ||
                r.END_DATE     || '|' ||
                r.ENTITYID     || '|' ||
                r.ENTITY       || '|' ||
                r.MANAGER      || '|' ||
                r.LASTNAME     || '|' ||
                r.FIRSTNAME    || '|' ||
                r.COUNTRY      || '|' ||
                r.LANGUAGE     || '|' ||
                r.FUNCTION     || '|' ||
                r.EMAIL        || '|' ||
                r.TYPE         || '|' ||
                r.STATUS       || '|' ||
                r.ISTEST       || '|' ||
                r.ISRPA        || '|' ||
                r.USER_TYPE
            FROM OWN_AP12008.STG_MASTER_ROBI r
            WHERE r.REFOG = h.REFOG)
        ),
        h.LAST_SEEN_ON  = v_current_batch_date,
        h.IS_ACTIVE     = 'Y'
    WHERE EXISTS (
        SELECT 1
        FROM OWN_AP12008.STG_MASTER_ROBI r
        WHERE r.REFOG = h.REFOG
    );

    -- ----------------------------------------------------------------
    -- STEP 2c: Detect DELETED identities
    -- REFOG was active in hash table but missing from today's load
    -- Like a fingerprint card still in the cabinet
    -- but the person didn't show up today
    -- ----------------------------------------------------------------
    INSERT INTO OWN_AP12008.STG_MASTER_ROBI_DELTA
        (REFOG, CHANGE_TYPE, BATCH_DATE, DETECTED_ON, IS_PROCESSED)
    SELECT
        h.REFOG,
        'DELETED',
        v_current_batch_date,
        SYSTIMESTAMP,
        'N'
    FROM OWN_AP12008.STG_MASTER_ROBI_HASH h
    WHERE h.IS_ACTIVE = 'Y'
      AND NOT EXISTS (
          SELECT 1
          FROM OWN_AP12008.STG_MASTER_ROBI r
          WHERE r.REFOG = h.REFOG
      );

    v_count_deleted := SQL%ROWCOUNT;

    -- Mark deleted identities as inactive in hash table
    -- Keep the row — just lower the IS_ACTIVE flag
    UPDATE OWN_AP12008.STG_MASTER_ROBI_HASH h
    SET
        h.IS_ACTIVE      = 'N',
        h.DEACTIVATED_ON = SYSTIMESTAMP
    WHERE h.IS_ACTIVE = 'Y'
      AND NOT EXISTS (
          SELECT 1
          FROM OWN_AP12008.STG_MASTER_ROBI r
          WHERE r.REFOG = h.REFOG
      );

    -- ----------------------------------------------------------------
    -- STEP 3: Commit all changes atomically
    -- ----------------------------------------------------------------
    COMMIT;

    DBMS_OUTPUT.PUT_LINE('=== SP_LOAD_STG_MASTER_ROBI_DELTA ===');
    DBMS_OUTPUT.PUT_LINE('Start time : ' || TO_CHAR(v_start_time,        'DD/MM/YYYY HH24:MI:SS'));
    DBMS_OUTPUT.PUT_LINE('End time   : ' || TO_CHAR(SYSTIMESTAMP,        'DD/MM/YYYY HH24:MI:SS'));
    DBMS_OUTPUT.PUT_LINE('Batch date : ' || TO_CHAR(v_current_batch_date,'DD/MM/YYYY'));
    DBMS_OUTPUT.PUT_LINE('NEW        : ' || v_count_new);
    DBMS_OUTPUT.PUT_LINE('CHANGED    : ' || v_count_changed);
    DBMS_OUTPUT.PUT_LINE('DELETED    : ' || v_count_deleted);

EXCEPTION
    WHEN OTHERS THEN
        ROLLBACK;
        DBMS_OUTPUT.PUT_LINE('ERROR: ' || SQLERRM);
        RAISE;
END SP_LOAD_STG_MASTER_ROBI_DELTA;
/

