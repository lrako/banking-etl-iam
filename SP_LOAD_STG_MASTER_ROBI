CREATE OR REPLACE FORCE EDITIONABLE VIEW "OWN_AP12008"."IS_MANAGER_VW" 
(
    "ROBID", "REFOG", "MANAGER", 
    "FIRSTNAME", "LASTNAME",
    "DIRECT_REPORTS_COUNT", "IS_MANAGER"
) AS
SELECT
    main.ROBID,
    main.REFOG,
    main.MANAGER,
    main.FIRSTNAME,
    main.LASTNAME,
    dr.direct_reports_count,
    (CASE
        WHEN dr.direct_reports_count > 0 THEN 'Y'
        ELSE 'N'
    END) AS IS_MANAGER
FROM OWN_AP12008.STG_MASTER_ROBI main
-- Pre-aggregate direct reports count then left join
LEFT JOIN (
    SELECT 
        MANAGER,
        COUNT(*) AS direct_reports_count
    FROM OWN_AP12008.STG_MASTER_ROBI
    WHERE MANAGER IS NOT NULL
    -- NO IS_CURRENT filter anymore - table is already current snapshot
    GROUP BY MANAGER
) dr ON dr.MANAGER = main.REFOG;
-- NO WHERE IS_CURRENT filter anymore

