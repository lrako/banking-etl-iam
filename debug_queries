-- Query A: Full delta table state
SELECT CHANGE_TYPE, IS_PROCESSED, BATCH_DATE, COUNT(*)
FROM OWN_AP12008.STG_MASTER_ROBI_DELTA
GROUP BY CHANGE_TYPE, IS_PROCESSED, BATCH_DATE
ORDER BY BATCH_DATE;

-- Query B: Are June 10 and June 11 rows both present?
SELECT COUNT(*) AS TOTAL_ROWS,
       COUNT(DISTINCT REFOG) AS DISTINCT_REFOGS,
       MIN(BATCH_DATE) AS EARLIEST,
       MAX(BATCH_DATE) AS LATEST
FROM OWN_AP12008.STG_MASTER_ROBI_DELTA
WHERE CHANGE_TYPE = 'NEW'
  AND IS_PROCESSED = 'N';

-- Query C: Check hash table state
SELECT IS_ACTIVE, COUNT(*)
FROM OWN_AP12008.STG_MASTER_ROBI_HASH
GROUP BY IS_ACTIVE;
