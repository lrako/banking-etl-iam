    public void execute(SailPointContext context, TaskResult taskResult, 
                       List<String> processedRoles) throws Exception {
        
        StringBuilder report = new StringBuilder();
        report.append("Role Import Summary\n");
        report.append("==================\n\n");
        
        int newRoles = 0;
        int updatedRoles = 0;
        int errors = 0;
        
        for (String roleName : processedRoles) {
            Bundle role = context.getObjectByName(Bundle.class, roleName);
            if (role != null) {
                // Trigger initial certification for new high-risk roles
                if (role.isHighRisk() && 
                    role.getAttribute("importDate").equals(role.getAttribute("createdDate"))) {
                    scheduleInitialCertification(context, role);
                    newRoles++;
                } else {
                    updatedRoles++;
                }
                
                // Add to access review campaigns if needed
                if (role.getAttribute("complianceFlags") != null) {
                    addToComplianceCampaigns(context, role);
                }
                
                report.append("✓ " + roleName + " - " + role.getAttribute("riskLevel") + "\n");
