#Step 3 - Preprocess validation rule


import java.io.File;
import java.util.HashMap;
import java.util.Map;
import javax.xml.parsers.DocumentBuilder;
import javax.xml.parsers.DocumentBuilderFactory;
import org.w3c.dom.Document;
import org.w3c.dom.Element;
import sailpoint.object.Bundle;
import sailpoint.object.Identity;
import sailpoint.tools.Message;

public class ValidateExternalRoleXML {
    
    public Map validateAndTransform(File xmlFile, Map context) throws Exception {
        Map<String, Object> result = new HashMap<>();
        List<Message> messages = new ArrayList<>();
        boolean isValid = true;
        
        try {
            // Parse XML
            DocumentBuilderFactory dbFactory = DocumentBuilderFactory.newInstance();
            DocumentBuilder dBuilder = dbFactory.newDocumentBuilder();
            Document doc = dBuilder.parse(xmlFile);
            doc.getDocumentElement().normalize();
            
            Element roleElement = doc.getDocumentElement();
            String roleName = roleElement.getAttribute("name");
            
            // Validation checks
            if (!roleName.startsWith("BANK_ROLE_")) {
                messages.add(Message.error("Role name must start with BANK_ROLE_: " + roleName));
                isValid = false;
            }
            
            // Check if role already exists
            Bundle existingRole = context.getObjectByName(Bundle.class, roleName);
            if (existingRole != null) {
                String externalId = roleElement.getElementsByTagName("entry")
                    .item(0).getAttribute("value");
                
                // Check if external ID matches
                if (!externalId.equals(existingRole.getAttribute("externalId"))) {
                    messages.add(Message.warn("Role exists with different external ID"));
                }
                result.put("isUpdate", true);
            }
            
            // Validate owner exists
            String ownerName = extractOwner(roleElement);
            Identity owner = context.getObjectByName(Identity.class, ownerName);
            if (owner == null) {
                messages.add(Message.error("Owner not found: " + ownerName));
                isValid = false;
            }
            
            // Check IT roles exist
            NodeList profiles = roleElement.getElementsByTagName("Reference");
            for (int i = 0; i < profiles.getLength(); i++) {
                Element profile = (Element) profiles.item(i);
                String itRoleName = profile.getAttribute("name");
                Bundle itRole = context.getObjectByName(Bundle.class, itRoleName);
                if (itRole == null) {
                    messages.add(Message.error("IT Role not found: " + itRoleName));
                    isValid = false;
                }
            }
            
            // Add compliance validation
            if (roleName.contains("PAYMENT") || roleName.contains("TREASURY")) {
                String complianceFlags = extractAttribute(roleElement, "complianceFlags");
                if (complianceFlags == null || !complianceFlags.contains("SOX")) {
                    messages.add(Message.warn("Payment/Treasury roles should have SOX compliance flag"));
                }
            }
            
        } catch (Exception e) {
            messages.add(Message.error("XML parsing error: " + e.getMessage()));
            isValid = false;
        }
        
        result.put("isValid", isValid);
        result.put("messages", messages);
        return result;
    }
}


# Role Import Rule

import sailpoint.object.Bundle;
import sailpoint.object.Filter;
import sailpoint.api.SailPointContext;
import sailpoint.tools.xml.XMLObjectFactory;
import java.io.File;
import java.util.Date;

public class RoleImportRule {
    
    public void importRole(SailPointContext context, File xmlFile, Map options) 
            throws Exception {
        
        log.info("Importing role from: " + xmlFile.getName());
        
        // Parse the XML into a Bundle object
        XMLObjectFactory xmlFactory = XMLObjectFactory.getInstance();
        Bundle role = (Bundle) xmlFactory.parseXml(context, xmlFile, true);
        
        // Enrich with additional metadata
        role.setAttribute("importDate", new Date());
        role.setAttribute("importSource", "External Role Modeler");
        role.setAttribute("importFile", xmlFile.getName());
        
        // Set elevated access based on risk level
        String riskLevel = (String) role.getAttribute("riskLevel");
        if ("High".equals(riskLevel) || "Critical".equals(riskLevel)) {
            role.setHighRisk(true);
        }
        
        // Handle role type classification
        classifyRole(role);
        
        // Check for existing role
        Bundle existingRole = context.getObjectByName(Bundle.class, role.getName());
        if (existingRole != null) {
            // Merge logic
            mergeRoles(existingRole, role);
            context.saveObject(existingRole);
            log.info("Updated existing role: " + role.getName());
        } else {
            // New role
            context.saveObject(role);
            log.info("Created new role: " + role.getName());
        }
        
        context.commitTransaction();
    }
    
    private void classifyRole(Bundle role) {
        String roleName = role.getName();
        
        // Auto-classify based on naming convention
        if (roleName.contains("ADMIN") || roleName.contains("SUPER")) {
            role.setAttribute("roleCategory", "Privileged");
            role.setHighRisk(true);
        } else if (roleName.contains("READ_ONLY") || roleName.contains("VIEWER")) {
            role.setAttribute("roleCategory", "ReadOnly");
        } else if (roleName.contains("APPROVER") || roleName.contains("MANAGER")) {
            role.setAttribute("roleCategory", "Approval");
        } else {
            role.setAttribute("roleCategory", "Standard");
        }
    }
    
    private void mergeRoles(Bundle existing, Bundle newRole) {
        // Preserve certain attributes from existing role
        newRole.setAttribute("createdDate", existing.getAttribute("createdDate"));
        newRole.setAttribute("lastCertificationDate", 
                           existing.getAttribute("lastCertificationDate"));
        
        // Update version
        Integer version = (Integer) existing.getAttribute("version");
        newRole.setAttribute("version", version != null ? version + 1 : 1);
        
        // Copy all attributes from new role to existing
        existing.setAttributes(newRole.getAttributes());
        existing.setProfiles(newRole.getProfiles());
        existing.setSelector(newRole.getSelector());
        existing.setDescription(newRole.getDescription());
        existing.setOwner(newRole.getOwner());
    }
}
