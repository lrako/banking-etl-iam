import java.sql.*;
import java.io.StringReader;
import sailpoint.object.*;
import sailpoint.api.SailPointContext;
import sailpoint.tools.xml.XMLObjectFactory;
import sailpoint.tools.Util;
import org.apache.commons.codec.digest.DigestUtils;

public class ProcessRoleImportQueueRule {
    
    private static final String FETCH_PENDING = 
        "SELECT ID, ROLE_NAME, EXTERNAL_ID, XML_CONTENT, RETRY_COUNT " +
        "FROM ROLE_IMPORT_QUEUE " +
        "WHERE STATUS IN ('PENDING', 'RETRY') " +
        "AND (RETRY_COUNT < ? OR STATUS = 'PENDING') " +
        "ORDER BY CREATED_DATE " +
        "FETCH FIRST ? ROWS ONLY";
    
    private static final String UPDATE_STATUS = 
        "UPDATE ROLE_IMPORT_QUEUE SET STATUS = ?, PROCESSED_DATE = ?, " +
        "PROCESSED_BY = ?, ERROR_MESSAGE = ?, RETRY_COUNT = ? WHERE ID = ?";
    
    private static final String INSERT_STATUS = 
        "INSERT INTO ROLE_IMPORT_STATUS (ID, IMPORT_ID, STATUS, MESSAGE, DETAILS) " +
        "VALUES (?, ?, ?, ?, ?)";
    
    public void execute(SailPointContext context, TaskResult taskResult, 
                       Map<String, Object> args) throws Exception {
        
        int batchSize = (Integer) args.get("batchSize");
        int maxRetries = (Integer) args.get("maxRetries");
        
        Connection conn = null;
        int processed = 0;
        int success = 0;
        int errors = 0;
        
        try {
            conn = getConnection(context);
            conn.setAutoCommit(false);
            
            // Fetch pending records
            List<RoleImportRecord> records = fetchPendingRecords(conn, maxRetries, batchSize);
            
            for (RoleImportRecord record : records) {
                try {
                    processRoleRecord(context, conn, record);
                    updateStatus(conn, record.id, "SUCCESS", null, record.retryCount);
                    success++;
                    
                } catch (ValidationException ve) {
                    // Validation failures don't retry
                    updateStatus(conn, record.id, "FAILED", ve.getMessage(), record.retryCount);
                    logStatusHistory(conn, record.id, "VALIDATION_FAILED", ve.getMessage());
                    errors++;
                    
                } catch (Exception e) {
                    // Other errors can retry
                    if (record.retryCount < maxRetries - 1) {
                        updateStatus(conn, record.id, "RETRY", e.getMessage(), 
                                   record.retryCount + 1);
                        logStatusHistory(conn, record.id, "RETRY_SCHEDULED", e.getMessage());
                    } else {
                        updateStatus(conn, record.id, "FAILED", 
                                   "Max retries exceeded: " + e.getMessage(), 
                                   record.retryCount);
                        errors++;
                    }
                }
                processed++;
                
                // Commit batch
                if (processed % 10 == 0) {
                    conn.commit();
                }
            }
            
            conn.commit();
            
            // Update task result
            taskResult.setAttribute("totalProcessed", processed);
            taskResult.setAttribute("successCount", success);
            taskResult.setAttribute("errorCount", errors);
            
            // Archive old successful records
            archiveProcessedRecords(conn);
            
        } finally {
            if (conn != null) {
                try { conn.close(); } catch (Exception e) {}
            }
        }
    }
    
    private void processRoleRecord(SailPointContext context, Connection conn, 
                                  RoleImportRecord record) throws Exception {
        
        log.info("Processing role import: " + record.roleName + 
                " (External ID: " + record.externalId + ")");
        
        // Validate XML hasn't been tampered with
        String checksum = DigestUtils.md5Hex(record.xmlContent);
        
        // Parse XML
        XMLObjectFactory xmlFactory = XMLObjectFactory.getInstance();
        Bundle role = (Bundle) xmlFactory.parseXml(context, 
                                                  new StringReader(record.xmlContent), 
                                                  true);
        
        // Validate role
        validateRole(context, role, record);
        
        // Check for duplicates by external ID
        checkDuplicates(context, record.externalId, role.getName());
        
        // Enrich metadata
        role.setAttribute("importId", record.id);
        role.setAttribute("externalId", record.externalId);
        role.setAttribute("importDate", new Date());
        role.setAttribute("importChecksum", checksum);
        
        // Check if update or create
        Bundle existingRole = context.getObjectByName(Bundle.class, role.getName());
        if (existingRole != null) {
            // Version control
            Integer version = (Integer) existingRole.getAttribute("version");
            role.setAttribute("version", version != null ? version + 1 : 2);
            role.setAttribute("previousImportId", existingRole.getAttribute("importId"));
            
            // Merge attributes
            mergeRoles(existingRole, role);
            context.saveObject(existingRole);
            
            logStatusHistory(conn, record.id, "UPDATED", 
                           "Role updated, version: " + role.getAttribute("version"));
        } else {
            // New role
            role.setAttribute("version", 1);
            context.saveObject(role);
            
            logStatusHistory(conn, record.id, "CREATED", "New role created");
        }
        
        context.commitTransaction();
    }
    
    private void validateRole(SailPointContext context, Bundle role, 
                             RoleImportRecord record) throws ValidationException {
        
        List<String> errors = new ArrayList<>();
        
        // Validate role name format
        if (!role.getName().matches("^BANK_ROLE_[A-Z0-9_]+$")) {
            errors.add("Invalid role name format: " + role.getName());
        }
        
        // Validate owner exists
        if (role.getOwner() != null) {
            String ownerName = role.getOwner().getName();
            Identity owner = context.getObjectByName(Identity.class, ownerName);
            if (owner == null) {
                errors.add("Owner not found: " + ownerName);
            }
        } else {
            errors.add("Role owner is required");
        }
        
        // Validate IT roles
        List<Profile> profiles = role.getProfiles();
        if (profiles != null) {
            for (Profile profile : profiles) {
                if (profile.getReference() != null) {
                    Bundle itRole = context.getObject(Bundle.class, profile.getReference());
                    if (itRole == null) {
                        errors.add("IT Role not found: " + profile.getReference().getName());
                    }
                }
            }
        }
        
        // Business validation
        String riskLevel = (String) role.getAttribute("riskLevel");
        if ("High".equals(riskLevel) || "Critical".equals(riskLevel)) {
            if (!role.isHighRisk()) {
                errors.add("High/Critical risk roles must have elevated access flag");
            }
        }
        
        if (!errors.isEmpty()) {
            throw new ValidationException("Role validation failed", errors);
        }
    }
    
    // Helper classes and methods
    class RoleImportRecord {
        String id;
        String roleName;
        String externalId;
        String xmlContent;
        int retryCount;
    }
    
    private Connection getConnection(SailPointContext context) throws Exception {
        Application app = context.getObjectByName(Application.class, "RoleImportDB");
        // Get connection from app config
        // In production, use proper connection pooling
        return DriverManager.getConnection(
            (String) app.getAttribute("url"),
            (String) app.getAttribute("user"),
            context.decrypt((String) app.getAttribute("password"))
        );
    }
    
    private void archiveProcessedRecords(Connection conn) throws SQLException {
        String archiveSql = 
            "INSERT INTO ROLE_IMPORT_ARCHIVE " +
            "SELECT *, CURRENT_TIMESTAMP, 'SUCCESS' FROM ROLE_IMPORT_QUEUE " +
            "WHERE STATUS = 'SUCCESS' AND PROCESSED_DATE < CURRENT_TIMESTAMP - 30";
        
        String deleteSql = 
            "DELETE FROM ROLE_IMPORT_QUEUE " +
            "WHERE STATUS = 'SUCCESS' AND PROCESSED_DATE < CURRENT_TIMESTAMP - 30";
        
        try (Statement stmt = conn.createStatement()) {
            stmt.executeUpdate(archiveSql);
            stmt.executeUpdate(deleteSql);
            conn.commit();
        }
    }
}


