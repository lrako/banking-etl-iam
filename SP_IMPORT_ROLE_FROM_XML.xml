#Database table design

-- Main table for role XML documents
CREATE TABLE ROLE_IMPORT_QUEUE (
    ID                  VARCHAR(128) PRIMARY KEY,
    ROLE_NAME          VARCHAR(255) NOT NULL,
    EXTERNAL_ID        VARCHAR(128) UNIQUE NOT NULL,
    XML_CONTENT        CLOB NOT NULL,
    STATUS             VARCHAR(50) DEFAULT 'PENDING',
    CREATED_DATE       TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    CREATED_BY         VARCHAR(128),
    PROCESSED_DATE     TIMESTAMP,
    PROCESSED_BY       VARCHAR(128),
    ERROR_MESSAGE      VARCHAR(4000),
    RETRY_COUNT        INT DEFAULT 0,
    VERSION            INT DEFAULT 1,
    CHECKSUM           VARCHAR(64),
    SOURCE_SYSTEM      VARCHAR(128) DEFAULT 'External Role Modeler'
);

-- Status tracking table
CREATE TABLE ROLE_IMPORT_STATUS (
    ID                  VARCHAR(128) PRIMARY KEY,
    IMPORT_ID          VARCHAR(128) REFERENCES ROLE_IMPORT_QUEUE(ID),
    STATUS             VARCHAR(50),
    STATUS_DATE        TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    MESSAGE            VARCHAR(4000),
    DETAILS            CLOB
);

-- Archive table for processed records
CREATE TABLE ROLE_IMPORT_ARCHIVE (
    -- Same structure as ROLE_IMPORT_QUEUE
    -- Plus:
    ARCHIVE_DATE       TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    ARCHIVE_REASON     VARCHAR(255)
);

-- Indexes for performance
CREATE INDEX IDX_RIQ_STATUS ON ROLE_IMPORT_QUEUE(STATUS);
CREATE INDEX IDX_RIQ_CREATED ON ROLE_IMPORT_QUEUE(CREATED_DATE);
CREATE INDEX IDX_RIQ_EXTERNAL_ID ON ROLE_IMPORT_QUEUE(EXTERNAL_ID);


